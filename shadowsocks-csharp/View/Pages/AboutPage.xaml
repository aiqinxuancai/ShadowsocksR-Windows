<Page x:Class="Shadowsocks.View.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="关于">

    <ScrollViewer>
        <StackPanel Margin="20" MaxWidth="800">
            <TextBlock Text="关于 ShadowsocksR" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <ui:Card Margin="0,0,0,10">
                <StackPanel Margin="20">
                    <TextBlock Text="版本信息" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="VersionText" Text="版本: 加载中..." Margin="0,5"/>
                    <TextBlock Text=".NET 9.0 with WPF-UI" Margin="0,5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,10">
                <StackPanel Margin="20">
                    <TextBlock Text="项目信息" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="ShadowsocksR Windows 客户端" Margin="0,5"/>
                    <TextBlock Margin="0,5">
                        <Hyperlink NavigateUri="https://github.com/shadowsocksrr/shadowsocksr-csharp" RequestNavigate="Hyperlink_RequestNavigate">
                            GitHub 项目地址
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </ui:Card>

            <ui:Card>
                <StackPanel Margin="20">
                    <TextBlock Text="开源许可" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="本项目基于 GPL v3 许可证开源" Margin="0,5" TextWrapping="Wrap"/>
                    <TextBlock Text="使用的开源组件:" Margin="0,10,0,5" FontWeight="SemiBold"/>
                    <TextBlock Text="• WPF-UI - Modern WPF UI library" Margin="5,2"/>
                    <TextBlock Text="• Hardcodet.NotifyIcon.Wpf - System tray support" Margin="5,2"/>
                    <TextBlock Text="• ZXing.Net - QR Code support" Margin="5,2"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
