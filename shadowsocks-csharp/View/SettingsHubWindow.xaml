<Window x:Class="Shadowsocks.View.SettingsHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Shadowsocks.View.Controls"
        xmlns:enums="clr-namespace:Shadowsocks.Enums"
        xmlns:model="clr-namespace:Shadowsocks.Model"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        xmlns:valueConverter="clr-namespace:Shadowsocks.View.ValueConverter"
        x:Name="HubWindow"
        Title="{DynamicResource Title}"
        Height="700"
        Width="940"
        MinHeight="640"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../I18N/SettingsHubWindow.en-US.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ObjectDataProvider x:Key="ProxyTypeEnum" MethodName="GetValues" ObjectType="{x:Type system:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:ProxyType" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
            <ObjectDataProvider x:Key="BalanceTypeEnum" MethodName="GetValues" ObjectType="{x:Type system:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:BalanceType" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
            <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="LightGray" />
            <Style TargetType="{x:Type TextBox}">
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource DisabledBackgroundBrush}" />
                    </Trigger>
                    <Trigger Property="IsReadOnly" Value="True">
                        <Setter Property="Background" Value="{StaticResource DisabledBackgroundBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <DataTemplate x:Key="SubscribeListBoxTemplate" DataType="model:ServerSubscribe">
                <StackPanel Margin="3">
                    <DockPanel><TextBlock Text="{Binding Tag}" Foreground="Green" FontWeight="Bold" /></DockPanel>
                    <DockPanel><TextBlock FontWeight="Bold" Text="{Binding Url}" Foreground="DarkOrange" DockPanel.Dock="Left" /></DockPanel>
                </StackPanel>
            </DataTemplate>
            <DataTemplate x:Key="DnsListBoxTemplate" DataType="model:DnsClient">
                <StackPanel Margin="3">
                    <WrapPanel>
                        <TextBlock Text="{Binding DnsServer}" Foreground="Green" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text=":" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="{Binding Port}" Foreground="DarkOrange" FontWeight="Bold" FontSize="16" />
                    </WrapPanel>
                </StackPanel>
            </DataTemplate>
            <valueConverter:ProxyTypeEnumConverter x:Key="ProxyTypeEnumConverter" />
            <valueConverter:BalanceTypeEnumConverter x:Key="BalanceTypeEnumConverter" />
            <valueConverter:UnixSecondsToString x:Key="UnixSecondsToStringConverter" />
            <valueConverter:ProxyTypeConverter x:Key="SubscribeProxyTypeConverter" />
            <valueConverter:ProxyTypeConverter x:Key="DnsTypeConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabControl">
            <TabItem Header="{DynamicResource GeneralTab}">
                <ScrollViewer x:Name="GeneralTabRoot" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="../I18N/SettingsWindow.en-US.xaml" />
                            </ResourceDictionary.MergedDictionaries>
                        </ResourceDictionary>
                    </ScrollViewer.Resources>
                    <Grid Margin="12" DataContext="{Binding SettingViewModel, ElementName=HubWindow}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <GroupBox Header="{DynamicResource RemoteProxy}" Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                            <Grid Margin="12,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition /></Grid.ColumnDefinitions>
                                <CheckBox Grid.Row="0" Grid.Column="0" Content="{DynamicResource ProxyOn}" Margin="0,0,10,5" IsChecked="{Binding ModifiedConfiguration.ProxyEnable,Mode=TwoWay}" />
                                <CheckBox Grid.Row="0" Grid.Column="1" Content="{DynamicResource Pac}" Margin="0,0,10,5" IsChecked="{Binding ModifiedConfiguration.PacDirectGoProxy,Mode=TwoWay}" />
                                <ComboBox Grid.Row="1" Grid.Column="1" Height="28" ItemsSource="{Binding Source={StaticResource ProxyTypeEnum}}" SelectedItem="{Binding ModifiedConfiguration.ProxyType,Mode=TwoWay}">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource ProxyTypeEnumConverter}}" /></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource ServerIp}" Margin="0,0,10,0" />
                                <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource ServerPort}" Margin="0,0,10,0" />
                                <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource Username}" Margin="0,0,10,0" />
                                <Label Grid.Row="5" Grid.Column="0" Content="{DynamicResource Password}" Margin="0,0,10,0" />
                                <Label Grid.Row="6" Grid.Column="0" Content="{DynamicResource UserAgent}" Margin="0,0,10,0" />
                                <TextBox Grid.Row="2" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Text="{Binding ModifiedConfiguration.ProxyHost,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                <controls:NumberUpDown Grid.Row="3" Grid.Column="1" Height="28" MinNum="1" MaxNum="65535" Value="{Binding ModifiedConfiguration.ProxyPort,Mode=TwoWay}" />
                                <TextBox Grid.Row="4" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Text="{Binding ModifiedConfiguration.ProxyAuthUser,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                <controls:BindablePasswordBox Grid.Row="5" Grid.Column="1" Height="28" Password="{Binding ModifiedConfiguration.ProxyAuthPass}" />
                                <TextBox Grid.Row="6" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Text="{Binding ModifiedConfiguration.ProxyUserAgent,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="{DynamicResource Misc}" Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                            <Grid Margin="12,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition /></Grid.ColumnDefinitions>
                                <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource Balance}" Margin="0,0,10,0" />
                                <Label Grid.Row="6" Grid.Column="0" Content="{DynamicResource Logging}" Margin="0,0,10,0" />
                                <Label Grid.Row="7" Grid.Column="0" Content="{DynamicResource Language}" Margin="0,0,10,0" />
                                <CheckBox x:Name="AutoStartupCheckBox" Grid.Row="0" Grid.Column="1" Content="{DynamicResource StartOnBoot}" Margin="0,0,10,0" Checked="AutoStartupCheckBox_CheckedChanged" Unchecked="AutoStartupCheckBox_CheckedChanged" />
                                <CheckBox Grid.Row="1" Grid.Column="1" Content="{DynamicResource SwitchAutoCloseTcpLinks}" Margin="0,0,10,0" IsChecked="{Binding ModifiedConfiguration.CheckSwitchAutoCloseAll,Mode=TwoWay}" />
                                <CheckBox Grid.Row="2" Grid.Column="1" Content="{DynamicResource LoadBalance}" Margin="0,0,10,0" IsChecked="{Binding ModifiedConfiguration.Random,Mode=TwoWay}" />
                                <ComboBox Grid.Row="3" Grid.Column="1" Height="28" ItemsSource="{Binding Source={StaticResource BalanceTypeEnum}}" SelectedItem="{Binding ModifiedConfiguration.BalanceType,Mode=TwoWay}">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource BalanceTypeEnumConverter}}" /></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                                <CheckBox Grid.Row="4" Grid.Column="1" Content="{DynamicResource BalanceInGroup}" Margin="0,0,10,0" IsChecked="{Binding ModifiedConfiguration.RandomInGroup,Mode=TwoWay}" />
                                <CheckBox Grid.Row="5" Grid.Column="1" Content="{DynamicResource AutoBan}" Margin="0,0,10,0" IsChecked="{Binding ModifiedConfiguration.AutoBan,Mode=TwoWay}" />
                                <CheckBox Grid.Row="6" Grid.Column="1" Content="{DynamicResource EnableLog}" Margin="0,0,10,0" IsChecked="{Binding ModifiedConfiguration.LogEnable,Mode=TwoWay}" />
                                <ComboBox Grid.Row="7" Grid.Column="1" Text="{Binding ModifiedConfiguration.LangName}" Height="28"><ComboBoxItem Content="en-US" /><ComboBoxItem Content="zh-CN" /><ComboBoxItem Content="zh-TW" /></ComboBox>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="{DynamicResource LocalProxy}" Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                            <Grid Margin="12,10">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition /></Grid.ColumnDefinitions>
                                <CheckBox Grid.Row="0" Grid.Column="1" Content="{DynamicResource AllowLan}" IsChecked="{Binding ModifiedConfiguration.ShareOverLan,Mode=TwoWay}" />
                                <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource LocalPort}" Margin="0,0,10,10" />
                                <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource Username}" Margin="0,0,10,10" />
                                <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource Password}" Margin="0,0,10,10" />
                                <controls:NumberUpDown Grid.Row="1" Grid.Column="1" Height="28" MinNum="1" MaxNum="65535" Value="{Binding ModifiedConfiguration.LocalPort,Mode=TwoWay}" />
                                <TextBox Grid.Row="2" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Text="{Binding ModifiedConfiguration.AuthUser,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                <controls:BindablePasswordBox Grid.Row="3" Grid.Column="1" Height="28" Password="{Binding ModifiedConfiguration.AuthPass,Mode=TwoWay}" />
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="{DynamicResource Misc}" Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                            <Grid Margin="12,10">
                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition /></Grid.ColumnDefinitions>
                                <Button Grid.Row="0" Grid.Column="1" Content="{DynamicResource SetDefault}" Click="DefaultButton_Click" Height="28" />
                                <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource ReconnectTimes}" Margin="0,0,10,0" />
                                <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource ConnectTimeout}" Margin="0,0,10,0" />
                                <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource Ttl}" Margin="0,0,10,0" />
                                <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource SubscribeUpdateInterval}" Margin="0,0,10,0" />
                                <controls:NumberUpDown Grid.Row="1" Grid.Column="1" Height="28" MinNum="0" MaxNum="20" Value="{Binding ModifiedConfiguration.ReconnectTimes,Mode=TwoWay}" />
                                <controls:NumberUpDown Grid.Row="2" Grid.Column="1" Height="28" MinNum="0" MaxNum="60" Value="{Binding ModifiedConfiguration.ConnectTimeout,Mode=TwoWay}" />
                                <controls:NumberUpDown Grid.Row="3" Grid.Column="1" Height="28" MinNum="0" MaxNum="600" Value="{Binding ModifiedConfiguration.Ttl,Mode=TwoWay}" />
                                <controls:NumberUpDown Grid.Row="4" Grid.Column="1" Height="28" MinNum="1" MaxNum="1440" Value="{Binding ModifiedConfiguration.SubscribeUpdateInterval,Mode=TwoWay}" />
                            </Grid>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{DynamicResource DnsTab}">
                <Grid x:Name="DnsTabRoot" Margin="12">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="../I18N/DnsSettingWindow.en-US.xaml" />
                            </ResourceDictionary.MergedDictionaries>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions><ColumnDefinition MinWidth="180" Width="260" /><ColumnDefinition Width="Auto" /><ColumnDefinition MinWidth="320" Width="*" /></Grid.ColumnDefinitions>
                    <ListBox Grid.Column="0" Margin="0,0,12,0" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" ItemsSource="{Binding DnsSettingViewModel.Clients,ElementName=HubWindow}" SelectedItem="{Binding DnsSettingViewModel.CurrentClient,ElementName=HubWindow,Mode=TwoWay}" ItemTemplate="{StaticResource DnsListBoxTemplate}">
                        <ListBox.ContextMenu><ContextMenu><MenuItem Header="{DynamicResource Add}" Click="DnsAddButton_OnClick" /><MenuItem Header="{DynamicResource Delete}" Click="DnsDeleteButton_OnClick" /></ContextMenu></ListBox.ContextMenu>
                    </ListBox>
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="4" />
                    <StackPanel Grid.Column="2" Margin="12,0,0,0" DataContext="{Binding DnsSettingViewModel,ElementName=HubWindow}" Visibility="{Binding IsCurrentClientNull,Mode=OneWay}">
                        <CheckBox x:Name="DnsEnableCheckBox" Margin="0,0,0,8" Content="{DynamicResource Enable}" IsChecked="{Binding CurrentClient.Enable}" />
                        <StackPanel IsEnabled="{Binding IsChecked,ElementName=DnsEnableCheckBox}">
                            <WrapPanel Margin="0,0,0,8"><RadioButton Content="{DynamicResource DnsDefault}" x:Name="DnsDefaultRadioButton" IsChecked="{Binding CurrentClient.DnsType,Converter={StaticResource DnsTypeConverter}, ConverterParameter={x:Static enums:DnsType.Default}}" /><RadioButton Content="{DynamicResource DnsOverTls}" Margin="10,0,0,0" IsChecked="{Binding CurrentClient.DnsType,Converter={StaticResource DnsTypeConverter}, ConverterParameter={x:Static enums:DnsType.DnsOverTls}}" /><CheckBox Margin="10,0,0,0" Content="{DynamicResource Ipv6}" IsChecked="{Binding CurrentClient.Ipv6First}" /></WrapPanel>
                            <WrapPanel Margin="0,0,0,8" IsEnabled="{Binding IsChecked,ElementName=DnsDefaultRadioButton}"><CheckBox Content="{DynamicResource Tcp}" IsChecked="{Binding CurrentClient.IsTcpEnabled}" /><CheckBox Margin="10,0,0,0" Content="{DynamicResource Udp}" IsChecked="{Binding CurrentClient.IsUdpEnabled}" /></WrapPanel>
                            <Grid Margin="0,0,0,8"><Grid.RowDefinitions><RowDefinition Height="32" /><RowDefinition Height="32" /><RowDefinition Height="32" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Address}" VerticalAlignment="Center" /><TextBox Grid.Row="0" Grid.Column="1" Margin="10,2,0,2" Text="{Binding CurrentClient.DnsServer,Mode=TwoWay}" VerticalContentAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Port}" VerticalAlignment="Center" /><controls:NumberUpDown Grid.Row="1" Grid.Column="1" Margin="10,2,0,2" MinNum="1" MaxNum="65535" Value="{Binding CurrentClient.Port,Mode=TwoWay}" /><TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Timeout}" VerticalAlignment="Center" /><controls:NumberUpDown Grid.Row="2" Grid.Column="1" Margin="10,2,0,2" MinNum="1" MaxNum="10000" Value="{Binding CurrentClient.Timeout,Mode=TwoWay}" /></Grid>
                            <GroupBox Margin="0,0,0,8" Header="{DynamicResource EDns}"><StackPanel Margin="10,8"><CheckBox x:Name="DnsEnableEDnsCheckBox" Content="{DynamicResource Enable}" IsChecked="{Binding CurrentClient.IsEDnsEnabled}" /><Grid Margin="0,8,0,0" IsEnabled="{Binding IsChecked,ElementName=DnsEnableEDnsCheckBox}"><Grid.RowDefinitions><RowDefinition Height="32" /><RowDefinition Height="32" /><RowDefinition Height="32" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Ip}" VerticalAlignment="Center" /><TextBox Grid.Row="0" Grid.Column="1" Margin="10,2,0,2" Text="{Binding CurrentClient.EcsIp,Mode=TwoWay}" VerticalContentAlignment="Center" /><TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource SourceNetmask}" VerticalAlignment="Center" /><controls:NumberUpDown Grid.Row="1" Grid.Column="1" Margin="10,2,0,2" MinNum="0" MaxNum="255" Value="{Binding CurrentClient.EcsSourceNetmask,Mode=TwoWay}" /><TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource ScopeNetmask}" VerticalAlignment="Center" /><controls:NumberUpDown Grid.Row="2" Grid.Column="1" Margin="10,2,0,2" MinNum="0" MaxNum="255" Value="{Binding CurrentClient.EcsScopeNetmask,Mode=TwoWay}" /></Grid></StackPanel></GroupBox>
                        </StackPanel>
                        <GroupBox Header="{DynamicResource Test}"><Grid Margin="10,8"><Grid.RowDefinitions><RowDefinition Height="32" /><RowDefinition Height="32" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Domain}" Margin="2,0,0,0" VerticalAlignment="Center" FontSize="14" /><TextBox x:Name="DnsDomainTextBox" Grid.Row="0" Grid.Column="1" Margin="10,2,0,2" Text="www.google.com" VerticalContentAlignment="Center" /><Button Grid.Row="1" Grid.Column="0" Content="{DynamicResource Test}" Padding="10,0" Click="DnsTestButton_OnClick" /><TextBox x:Name="DnsAnswerTextBox" Grid.Row="1" Grid.Column="1" Margin="10,2,0,2" IsReadOnly="True" Background="{StaticResource DisabledBackgroundBrush}" VerticalContentAlignment="Center" /></Grid></GroupBox>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource PortTab}">
                <Grid x:Name="PortTabRoot" Margin="12">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="../I18N/PortSettingsWindow.en-US.xaml" />
                            </ResourceDictionary.MergedDictionaries>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <Grid.RowDefinitions><RowDefinition /><RowDefinition Height="Auto" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="260" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><ListBox x:Name="PortPortsListBox" Grid.Row="0" Grid.Column="0" Margin="0,0,12,0" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" SelectionChanged="PortPortsListBox_SelectionChanged" /><GroupBox Grid.Row="0" Grid.Column="1" Header="{DynamicResource MapSetting}"><Grid Margin="16,12"><Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><CheckBox x:Name="PortEnableCheckBox" Grid.Row="0" Grid.Column="1" Content="{DynamicResource Enable}" Margin="0,0,0,8" /><Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource Type}" /><Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource ServerId}" /><Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource LocalPort}" /><Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource TargetAddress}" /><Label Grid.Row="5" Grid.Column="0" Content="{DynamicResource TargetPort}" /><Label Grid.Row="6" Grid.Column="0" Content="{DynamicResource Remarks}" /><ComboBox x:Name="PortTypeComboBox" Grid.Row="1" Grid.Column="1" Height="28" DisplayMemberPath="Text" SelectedValuePath="Value" SelectionChanged="PortTypeComboBox_SelectionChanged" /><ComboBox x:Name="PortServersComboBox" Grid.Row="2" Grid.Column="1" Height="28" /><controls:NumberUpDown x:Name="PortLocalPortNumber" Grid.Row="3" Grid.Column="1" Height="28" MinNum="0" MaxNum="65535" /><TextBox x:Name="PortTargetAddressTextBox" Grid.Row="4" Grid.Column="1" Height="28" VerticalContentAlignment="Center" /><controls:NumberUpDown x:Name="PortTargetPortNumber" Grid.Row="5" Grid.Column="1" Height="28" MinNum="0" MaxNum="65535" /><TextBox x:Name="PortRemarksTextBox" Grid.Row="6" Grid.Column="1" Height="28" VerticalContentAlignment="Center" /></Grid></GroupBox><Grid Grid.Row="1" Grid.Column="0" Margin="0,12,12,0"><Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions><Button Grid.Column="0" Content="{DynamicResource Add}" FontSize="14" Click="PortAddButton_Click" /><Button Grid.Column="1" Content="{DynamicResource Delete}" FontSize="14" Margin="8,0,0,0" Click="PortDeleteButton_Click" /></Grid></Grid>
            </TabItem>
            <TabItem Header="{DynamicResource SubscribeTab}">
                <Grid x:Name="SubscribeTabRoot" Margin="12">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="../I18N/SubscribeWindow.en-US.xaml" />
                            </ResourceDictionary.MergedDictionaries>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <Grid.RowDefinitions><RowDefinition /><RowDefinition Height="Auto" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="300" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><ListBox x:Name="SubscribeListBox" Grid.Row="0" Grid.Column="0" Margin="0,0,12,0" SelectionChanged="SubscribeListBox_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" ItemsSource="{Binding SubscribeWindowViewModel.SubscribeCollection,ElementName=HubWindow}" ItemTemplate="{StaticResource SubscribeListBoxTemplate}" SelectedItem="{Binding SubscribeWindowViewModel.SelectedServer,ElementName=HubWindow,Mode=TwoWay}" /><GridSplitter Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="4" /><StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,0"><Grid x:Name="SubscribeInfoGrid"><Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource Url}" Margin="0,3" /><Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource GroupName}" Margin="0,3" /><Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource LastUpdate}" Margin="0,3" /><TextBox Grid.Row="0" Grid.Column="1" Margin="0,3" VerticalContentAlignment="Center" Text="{Binding SubscribeWindowViewModel.SelectedServer.Url,ElementName=HubWindow,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Row="1" Grid.Column="1" Margin="0,3" VerticalContentAlignment="Center" Text="{Binding SubscribeWindowViewModel.SelectedServer.Tag,ElementName=HubWindow,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Row="2" Grid.Column="1" Margin="0,3" IsReadOnly="True" Background="{StaticResource DisabledBackgroundBrush}" VerticalContentAlignment="Center" Text="{Binding SubscribeWindowViewModel.SelectedServer.LastUpdateTime,ElementName=HubWindow,Converter={StaticResource UnixSecondsToStringConverter},Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" /><CheckBox Grid.Row="3" Grid.Column="1" Content="{DynamicResource AutoUpdate}" Margin="0,10,0,0" IsChecked="{Binding SubscribeWindowViewModel.SelectedServer.AutoCheckUpdate,ElementName=HubWindow,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" /><GroupBox Grid.Row="4" Grid.Column="1" Header="{DynamicResource ProxyType}" Margin="0,10,0,0"><StackPanel Margin="10,8"><RadioButton Content="{DynamicResource Auto}" IsChecked="{Binding SubscribeWindowViewModel.SelectedServer.ProxyType,ElementName=HubWindow,Converter={StaticResource SubscribeProxyTypeConverter},ConverterParameter={x:Static enums:HttpRequestProxyType.Auto}}" /><RadioButton Content="{DynamicResource Direct}" IsChecked="{Binding SubscribeWindowViewModel.SelectedServer.ProxyType,ElementName=HubWindow,Converter={StaticResource SubscribeProxyTypeConverter},ConverterParameter={x:Static enums:HttpRequestProxyType.Direct}}" /><RadioButton Content="{DynamicResource Proxy}" IsChecked="{Binding SubscribeWindowViewModel.SelectedServer.ProxyType,ElementName=HubWindow,Converter={StaticResource SubscribeProxyTypeConverter},ConverterParameter={x:Static enums:HttpRequestProxyType.Proxy}}" /><RadioButton Content="{DynamicResource SystemSetting}" IsChecked="{Binding SubscribeWindowViewModel.SelectedServer.ProxyType,ElementName=HubWindow,Converter={StaticResource SubscribeProxyTypeConverter},ConverterParameter={x:Static enums:HttpRequestProxyType.SystemSetting}}" /></StackPanel></GroupBox><Button Grid.Row="5" Grid.Column="1" Content="{DynamicResource Update}" Margin="0,10,0,0" Click="SubscribeUpdateButton_OnClick" /></Grid></StackPanel><Grid Grid.Row="1" Grid.Column="0" Margin="0,12,12,0"><Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions><Button Grid.Column="0" Content="{DynamicResource Add}" FontSize="14" Click="SubscribeAddButton_Click" /><Button Grid.Column="1" Content="{DynamicResource Delete}" Margin="8,0,0,0" FontSize="14" Click="SubscribeDeleteButton_Click" /></Grid></Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{DynamicResource Ok}" Padding="12,2" Margin="10,0,0,0" FontSize="14" Click="OkButton_Click" />
            <Button Grid.Column="1" Content="{DynamicResource Cancel}" Padding="12,2" Margin="10,0,0,0" FontSize="14" Click="CancelButton_Click" />
            <Button x:Name="ApplyButton" Grid.Column="2" Content="{DynamicResource Apply}" Padding="12,2" Margin="10,0,0,0" FontSize="14" Click="ApplyButton_Click" />
        </Grid>
    </Grid>
</Window>
